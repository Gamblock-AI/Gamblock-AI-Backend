# Gamblock-AI Backend — Environment Variables
# This file is the single source of truth for configuration keys read by
# internal/config/config.go (viper). Copy to `.env` and fill in real values.
# Secrets MUST live only in `.env` (gitignored), never committed.

# --- App ---
APP_ENV=development
ENABLE_DEV_LOGIN=false
ENABLE_DEMO_DATA=false
HTTP_ADDR=:8080
PUBLIC_WEB_BASE_URL=http://localhost:3000
NOTIFICATION_MODE=demo

# --- Database ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable

# --- Auth (JWT) ---
# Generate a long random secret: openssl rand -hex 32
JWT_ACCESS_SECRET=dev-only-change-me
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=720h

# --- OAuth ---
GOOGLE_CLIENT_ID=

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8099,http://127.0.0.1:8099

# --- Storage paths ---
ARTIFACT_STORAGE_PATH=./var/artifacts
EXPORT_STORAGE_PATH=./var/exports

# --- AES-256 journal encryption (PRD §4 / §7.1) ---
# 32-byte hex key. Generate with: openssl rand -hex 32
JOURNAL_ENCRYPTION_KEY=

# --- WhatsApp Business API (PRD §5) ---
# When unset/NOTIFICATION_MODE=demo, the backend uses a no-op/log adapter.
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=
WHATSAPP_BASE_URL=https://graph.facebook.com/v18.0
