# Gamblock-AI Backend — Environment Variables
# This file is the single source of truth for configuration keys read by
# internal/config/config.go (viper). Copy to `.env` and fill in real values.
# Secrets MUST live only in `.env` (gitignored), never committed.

# --- App ---
APP_ENV=development
ENABLE_DEV_LOGIN=false
ENABLE_DEMO_DATA=false
HTTP_ADDR=:8080
PUBLIC_WEB_BASE_URL=http://localhost:3000
NOTIFICATION_MODE=demo

# --- Database ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable

# --- Auth (JWT) ---
# Generate a long random secret: openssl rand -hex 32
JWT_ACCESS_SECRET=dev-only-change-me
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=720h

# --- OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8099,http://127.0.0.1:8099

# --- Storage paths ---
ARTIFACT_STORAGE_PATH=./var/artifacts
EXPORT_STORAGE_PATH=./var/exports
# Uploaded psychoeducation images, video, and PDF files. Use a persistent
# volume in deployed environments.
MEDIA_STORAGE_PATH=./var/media/education
# Uploaded account avatars. Keep this on a persistent volume separate from
# psychoeducation media so ownership and retention stay scoped to the account.
AVATAR_STORAGE_PATH=./var/media/avatars
# Exact HTTPS hosts allowed for click-to-load external education media.
MEDIA_EMBED_ALLOWED_HOSTS=www.youtube-nocookie.com,player.vimeo.com,who.int,www.who.int,ppatk.go.id,www.ppatk.go.id,ojk.go.id,www.ojk.go.id,komdigi.go.id,www.komdigi.go.id,kemkes.go.id,www.kemkes.go.id

# --- AES-256 account-content/export encryption (PRD §4 / §7.1) ---
# Required in every environment. Run `make key-generate` after copying this
# file to `.env`; it creates and stores a unique 32-byte hex key safely.
JOURNAL_ENCRYPTION_KEY=

# --- WhatsApp Business API (PRD §5) ---
# When unset/NOTIFICATION_MODE=demo, the backend uses a no-op/log adapter.
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=
WHATSAPP_BASE_URL=https://graph.facebook.com/v18.0

# --- Transactional email (SMTP, optional delivery adapter) ---
# When empty, the API still starts but verification/reset/export notification
# delivery is unavailable. Never enable demo notification mode in production.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
